    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:data": "ts-node --project tsconfig.scripts.json scripts/build-data.ts",
    "scrape:list": "ts-node --project tsconfig.scripts.json scripts/scrape-list.ts",
    "scrape:photos": "ts-node --project tsconfig.scripts.json scripts/scrape-photos.ts",
    "scrape:nies": "ts-node --project tsconfig.scripts.json scripts/scrape-nies.ts",
    "download:images": "ts-node --project tsconfig.scripts.json scripts/download-images.ts",
    "scrape:descriptions": "ts-node --project tsconfig.scripts.json scripts/scrape-descriptions.ts",
    "scrape:wikimedia": "ts-node --project tsconfig.scripts.json scripts/scrape-wikimedia.ts",
    "scrape:kouji": "ts-node --project tsconfig.scripts.json scripts/scrape-kouji.ts",
    "backfill:env-credits": "ts-node --project tsconfig.scripts.json scripts/backfill-env-credits.ts",
    "apply:lookalikes": "ts-node --project tsconfig.scripts.json scripts/apply-lookalikes.ts",
